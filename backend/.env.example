# ─────────────────────────────────────────────────────────────
#  Meeting Task Manager — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Local:   postgresql://postgres:yourpassword@localhost:5432/meeting_task_manager
# Azure:   postgresql://adminuser:password@server.postgres.database.azure.com/meeting_task_manager
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/meeting_task_manager

# ── JWT Authentication ────────────────────────────────────────
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-me-with-a-strong-random-secret

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Azure OpenAI ──────────────────────────────────────────────
# Found at: Azure Portal → OpenAI resource → Keys and Endpoint
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=your-gpt4-deployment-name

# ── CORS (Production only) ────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave empty for local development (localhost fallback is used).
# Example: https://app.yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=

# ── Transcript limits ─────────────────────────────────────────
# Maximum number of characters extracted from a transcript before
# sending to the AI. Prevents excessive token costs.
MAX_TRANSCRIPT_CHARS=50000

# ── Production server (Gunicorn) ──────────────────────────────
# Number of Gunicorn workers. Rule of thumb: 2 × vCPUs
WORKERS=2
LOG_LEVEL=info
